{
  "name": "automation-control",
  "productName": "InternalX",
  "version": "1.0.9",
  "description": "Automation Control Application",
  "main": "dist-electron/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:icons": "node scripts/generate-app-icon.mjs",
    "predev": "node scripts/generate-app-icon.mjs",
    "dev": "vite",
    "prebuild": "node scripts/generate-app-icon.mjs",
    "build": "tsc -b && vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "tailwindcss": "3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.internalx.app",
    "productName": "InternalX",
    "copyright": "Copyright © InternalX",
    "afterPack": "./electron/afterpack.cjs",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "icon.ico",
          "icon.png",
          "tray-running.png",
          "tray-running@2x.png",
          "tray-stopped.png",
          "tray-stopped@2x.png",
          "sound/start-end.mp3",
          "sound/second-beep.mp3"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*.py",
          "requirements.txt",
          "lib/**/*.py"
        ]
      },
      {
        "from": "electron/scripts",
        "to": "scripts",
        "filter": [
          "**/*.ps1",
          "**/*.applescript"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "shortcutName": "InternalX"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "dmg": {
      "title": "InternalX ${version}"
    }
  }
}
